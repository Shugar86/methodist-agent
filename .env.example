# Methodist Agent — пример конфигурации.
# Скопируйте в .env и заполните ключами того провайдера, который укажете primary
# в ~/.methodist-agent/config.yaml: cp .env.example .env

# LLM-провайдеры. По умолчанию (см. src/core/config.py):
#   primary  — OpenAI, модель gpt-4o
#   fallback — Anthropic, модель Claude
# Достаточно ключа активного провайдера; второй нужен только для fallback.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
